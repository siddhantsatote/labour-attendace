{
  "expo": {
    "name": "Labour Attendance",
    "slug": "labour-attendance-face",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is required to scan worker faces for attendance."
      }
    },
    "android": {
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-camera"
    ]
  }
}
